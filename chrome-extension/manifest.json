{
  "name": "Kubryx Multi-Tool OS",
  "version": "1.0",
  "manifest_version": 3,
  "description": "Access all Kubryx tools instantly directly from your browser's side panel.",
  "permissions": [
    "sidePanel"
  ],
  "side_panel": {
    "default_path": "panel.html"
  },
  "action": {
    "default_title": "Open Kubryx Side Panel"
  },
  "background": {
    "service_worker": "background.js"
  }
}
